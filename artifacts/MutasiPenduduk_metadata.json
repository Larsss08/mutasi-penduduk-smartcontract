		"devdoc": {
			"author": "Sistem Kelurahan Digital Fitur Utama: - Integritas Data: Setiap catatan mutasi tersimpan permanen di blockchain - Verifikasi: Hanya petugas berwenang yang dapat mencatat mutasi - Transparansi: Semua warga dapat melihat statistik kependudukan - Otomatisasi: Statistik dihitung otomatis tanpa rekap manual",
			"details": "Smart Contract untuk Pencatatan Log Keluar-Masuk Penduduk (Mutasi)",
			"kind": "dev",
			"methods": {
				"catatMutasiKeluar(string,string,string,string,string)": {
					"details": "Catat warga yang KELUAR dari lingkungan",
					"params": {
						"_alamatTujuan": "Alamat tujuan setelah pindah",
						"_alasanMutasi": "Alasan pindah keluar",
						"_namaLengkap": "Nama lengkap warga",
						"_nik": "NIK warga (16 digit)",
						"_nomorSuratPindah": "Nomor dokumen surat pindah resmi"
					}
				},
				"catatMutasiMasuk(string,string,string,string,string)": {
					"details": "Catat warga yang MASUK ke lingkungan",
					"params": {
						"_alamatAsal": "Alamat asal sebelum pindah",
						"_alasanMutasi": "Alasan pindah masuk",
						"_namaLengkap": "Nama lengkap warga",
						"_nik": "NIK warga (16 digit)",
						"_nomorSuratPindah": "Nomor dokumen surat pindah resmi"
					}
				},
				"cekNIKAktif(string)": {
					"details": "Cek apakah NIK terdaftar aktif di lingkungan"
				},
				"constructor": {
					"details": "Inisialisasi kontrak dengan nama lingkungan",
					"params": {
						"_namaLingkungan": "Nama RT/RW/Kelurahan yang menggunakan sistem ini"
					}
				},
				"getCatatanMutasi(uint256)": {
					"details": "Ambil detail satu catatan mutasi berdasarkan ID"
				},
				"getListMutasi(uint256,uint256)": {
					"details": "Ambil daftar ID mutasi dengan pagination",
					"params": {
						"_limit": "Jumlah data yang diambil",
						"_offset": "Indeks awal"
					}
				},
				"getRiwayatNIK(string)": {
					"details": "Ambil semua ID mutasi milik satu NIK"
				},
				"getStatistik()": {
					"details": "Ambil statistik kependudukan lengkap"
				},
				"getTotalMutasi()": {
					"details": "Ambil total jumlah catatan mutasi"
				},
				"kelolaPetugas(address,bool)": {
					"details": "Daftarkan atau cabut akses petugas",
					"params": {
						"_petugas": "Alamat wallet petugas",
						"_status": "true = aktifkan, false = nonaktifkan"
					}
				},
				"perbaruiStatusVerifikasi(uint256,uint8)": {
					"details": "Perbarui status verifikasi dokumen mutasi",
					"params": {
						"_id": "ID catatan mutasi",
						"_status": "Status verifikasi baru"
					}
				}
			},
